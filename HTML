<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Reymart | Lead Generation & Automation Specialist</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
<style>
  :root {
    --bg: #060b18;
    --bg2: #0c1628;
    --surface: #0f1e38;
    --surface2: #152545;
    --accent: #00c8ff;
    --accent2: #0af0b0;
    --accent3: #7b6ff0;
    --text: #e8f0fe;
    --muted: #7a92b8;
    --border: rgba(0,200,255,0.12);
    --glow: rgba(0,200,255,0.18);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
    line-height: 1.7;
  }

  /* ── Background mesh ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 10% 0%, rgba(0,200,255,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 90% 80%, rgba(123,111,240,0.08) 0%, transparent 55%),
      radial-gradient(ellipse 50% 60% at 50% 50%, rgba(10,240,176,0.04) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 5%;
    height: 68px;
    background: rgba(6,11,24,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--accent);
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 0; right: 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .nav-links a:hover { color: var(--accent); }
  .nav-links a:hover::after { transform: scaleX(1); }

  /* ── SECTIONS ── */
  section { position: relative; z-index: 1; }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 5% 80px;
  }

  .avatar-ring {
    position: relative;
    width: 148px;
    height: 148px;
    margin: 0 auto 2rem;
    animation: fadeUp 0.8s ease both;
  }

  .avatar-ring::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--accent), var(--accent3), var(--accent2), var(--accent));
    animation: spin 6s linear infinite;
  }

  .avatar-ring::after {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    background: conic-gradient(from 180deg, rgba(0,200,255,0.2), transparent, rgba(123,111,240,0.2), transparent);
    animation: spin 10s linear infinite reverse;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .avatar-img {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    z-index: 1;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3.5rem;
  }

  .avatar-placeholder {
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a2d50, #0c1a35);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    overflow: hidden;
  }

  .avatar-placeholder svg {
    width: 70%;
    height: 70%;
    opacity: 0.5;
    fill: var(--muted);
  }

  .hero-name {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    animation: fadeUp 0.8s 0.1s ease both;
  }

  .hero-name .wave { display: inline-block; animation: waveHand 1.5s 1s ease both; }
  @keyframes waveHand {
    0%,100% { transform: rotate(0); }
    25% { transform: rotate(20deg); }
    75% { transform: rotate(-10deg); }
  }

  .hero-title {
    margin-top: 0.75rem;
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    font-weight: 500;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0.04em;
    animation: fadeUp 0.8s 0.2s ease both;
  }

  .hero-tags {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    animation: fadeUp 0.8s 0.3s ease both;
  }

  .tag {
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    border: 1px solid var(--border);
    background: rgba(0,200,255,0.06);
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .hero-cta {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    animation: fadeUp 0.8s 0.4s ease both;
  }

  .btn {
    padding: 0.75rem 2rem;
    border-radius: 8px;
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.25s ease;
    display: inline-block;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: var(--bg);
    border: none;
    box-shadow: 0 0 28px rgba(0,200,255,0.35);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 40px rgba(0,200,255,0.5);
  }

  .btn-ghost {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .btn-ghost:hover {
    background: rgba(0,200,255,0.08);
    transform: translateY(-2px);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── SECTION WRAPPER ── */
  .section-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 80px 5%;
  }

  .section-label {
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .section-title .highlight {
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* divider */
  .divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
    margin: 0;
  }

  /* ── ABOUT ── */
  #about { background: rgba(12,22,40,0.5); }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 4rem;
    align-items: start;
  }

  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    transition: border-color 0.25s, transform 0.25s;
  }

  .stat-card:hover {
    border-color: rgba(0,200,255,0.35);
    transform: translateX(4px);
  }

  .stat-number {
    font-family: 'Syne', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.82rem;
    color: var(--muted);
    font-weight: 400;
    letter-spacing: 0.04em;
  }

  .about-text p {
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.85;
    margin-bottom: 1rem;
  }

  .about-text p strong {
    color: var(--text);
    font-weight: 500;
  }

  /* ── SERVICES ── */
  #services {}

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .service-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,200,255,0.05), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .service-card:hover { border-color: rgba(0,200,255,0.3); transform: translateY(-4px); }
  .service-card:hover::before { opacity: 1; }

  .service-icon {
    width: 46px;
    height: 46px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(0,200,255,0.15), rgba(10,240,176,0.1));
    border: 1px solid rgba(0,200,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .service-name {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
  }

  .service-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.65;
  }

  /* ── WORK / PORTFOLIO ── */
  #work { background: rgba(12,22,40,0.5); }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .work-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.4rem 1.5rem;
    cursor: pointer;
    transition: all 0.25s ease;
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
  }

  .work-card:hover {
    border-color: rgba(10,240,176,0.35);
    transform: translateY(-3px);
    background: var(--surface2);
  }

  .work-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent2);
    margin-top: 6px;
    flex-shrink: 0;
    box-shadow: 0 0 10px rgba(10,240,176,0.5);
  }

  .work-name {
    font-family: 'Syne', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  .work-tag {
    display: inline-block;
    margin-top: 0.4rem;
    font-size: 0.72rem;
    color: var(--accent2);
    background: rgba(10,240,176,0.08);
    border: 1px solid rgba(10,240,176,0.15);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  /* ── CONTACT ── */
  #contact {}

  .contact-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    max-width: 620px;
    margin: 2rem auto 0;
  }

  .contact-box::before {
    content: '';
    position: absolute;
    top: -50%; left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,200,255,0.08), transparent 70%);
    pointer-events: none;
  }

  .contact-box p {
    font-size: 1rem;
    color: var(--muted);
    margin-bottom: 2rem;
    line-height: 1.75;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: center;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.75rem 1.75rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(0,200,255,0.05);
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.25s;
    min-width: 300px;
    justify-content: center;
  }

  .contact-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(0,200,255,0.1);
    transform: translateY(-2px);
  }

  .contact-link .icon { font-size: 1.1rem; }

  /* ── FOOTER ── */
  footer {
    text-align: center;
    padding: 2rem 5%;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--muted);
    position: relative;
    z-index: 1;
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 720px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
    .nav-links { gap: 1.2rem; }
    .contact-link { min-width: unset; width: 100%; }
  }
</style>
</head>
